---
import Landing from '../layouts/Landing.astro';
import FloatingActions from '../components/FloatingActions.astro';
import FishBackground from '../components/FishBackground.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import DemoCallout from '../components/DemoCallout.astro';
import Quickstart from '../components/Quickstart.astro';
import Screenshots from '../components/Screenshots.astro';
import Footer from '../components/Footer.astro';
---

<Landing>
  <main id="main">
    <Hero />
    <Features />
    <DemoCallout />
    <Quickstart />
    <Screenshots />
  </main>
  <Footer />
  <FloatingActions />
  <FishBackground />
</Landing>

