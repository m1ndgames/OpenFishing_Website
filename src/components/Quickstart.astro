---
import { SITE } from '../consts';

const cmd = `docker run -d -p 3000:3000 \\
  -v openfishing-db:/app/data \\
  -v openfishing-uploads:/app/uploads \\
  ghcr.io/m1ndgames/openfishing:latest`;
---

<section class="qs">
  <div class="qs-inner">
    <div class="qs-copy">
      <h2>Up and running in one command.</h2>
      <p>
        OpenFishing ships as a single container. Point two volumes at persistent storage for
        the SQLite database and your uploads, and you're fishing. Then open
        <code>http://localhost:3000</code>.
      </p>
      <a class="btn-text" href={SITE.docs}>
        Full docs
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="qs-code card">
      <div class="qs-code-bar">
        <span class="qs-dot"></span><span class="qs-dot"></span><span class="qs-dot"></span>
        <span class="qs-file">docker run</span>
        <button id="copy-run" class="qs-copy-btn" type="button" aria-label="Copy command">Copy</button>
      </div>
      <pre><code id="run-cmd">{cmd}</code></pre>
    </div>
  </div>
</section>

<style>
  .qs {
    border-bottom: 1px solid var(--of-border-subtle);
  }
  .qs-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 1.25rem;
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .qs-copy h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.75rem;
  }
  .qs-copy p {
    color: var(--of-text-2);
    line-height: 1.6;
    margin: 0 0 1rem;
  }
  .qs-copy code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--of-accent);
    background: var(--of-accent-bg);
    padding: 0.1rem 0.35rem;
    border-radius: 6px;
  }
  .qs-code {
    overflow: hidden;
  }
  .qs-code-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 12px;
    background: var(--of-bg-elevated);
    border-bottom: 1px solid var(--of-border-subtle);
  }
  .qs-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--of-border-strong);
  }
  .qs-file {
    margin-left: 0.5rem;
    color: var(--of-text-2);
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  .qs-copy-btn {
    margin-left: auto;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--of-text-2);
    background: var(--of-bg-surface);
    border: 1px solid var(--of-border);
    border-radius: 6px;
    padding: 0.2rem 0.55rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .qs-copy-btn:hover {
    color: var(--of-accent);
    border-color: var(--of-accent-border);
  }
  .qs-code pre {
    margin: 0;
    padding: 1.1rem 1.2rem;
    overflow-x: auto;
    background: var(--of-bg-surface);
  }
  .qs-code code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--of-text);
    white-space: pre;
  }

  @media (max-width: 820px) {
    .qs-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const btn = document.getElementById('copy-run');
  const code = document.getElementById('run-cmd');
  btn?.addEventListener('click', async () => {
    if (!code?.textContent) return;
    try {
      await navigator.clipboard.writeText(code.textContent);
      const prev = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = prev), 1500);
    } catch (e) {}
  });
</script>
