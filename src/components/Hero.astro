---
import { SITE } from '../consts';
import Logo from './Logo.astro';

const slides = [
  { src: '/screenshots/hero.jpg',         alt: 'OpenFishing lure library showing a grid of photo cards with tags and catch counts' },
  { src: '/screenshots/catch-detail.jpg', alt: 'A single catch with its map location and Bite Index score' },
  { src: '/screenshots/spot-map.jpg',     alt: 'Interactive map with saved fishing-spot markers' },
  { src: '/screenshots/stats.jpg',        alt: 'Statistics dashboard of catch and gear trends' },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-brand">
        <Logo class="hero-logo" />
        <h1 class="hero-title">Your tackle box,<br /><span class="accent">organized.</span></h1>
      </div>
      <p class="hero-sub">
        A self-hosted fishing log for your lures, spots, catches &amp; tackle
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={SITE.demo} target="_blank" rel="noopener">Try the live demo</a>
        <a class="btn-ghost" href={SITE.docs}>Get started</a>
        <a class="btn-text" href={SITE.github} target="_blank" rel="noopener">
          View on GitHub
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="hero-shot card">
      <div class="shot-bar" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <a class="carousel" id="hero-carousel" href={SITE.demo} target="_blank" rel="noopener" aria-label="Open live demo">
        <div class="carousel-track" id="hero-track">
          {slides.map((s, i) => (
            <div class="carousel-slide" aria-hidden={i > 0 ? 'true' : undefined}>
              <img
                src={s.src}
                alt={s.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
              />
            </div>
          ))}
        </div>
        <div class="carousel-dots" id="hero-dots" role="tablist" aria-label="Slides">
          {slides.map((_, i) => (
            <button
              class:list={['dot', { active: i === 0 }]}
              role="tab"
              aria-label={`Slide ${i + 1}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              data-index={String(i)}
            />
          ))}
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    border-bottom: 1px solid var(--of-border-subtle);
  }
  .hero-inner {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3rem, 5vw, 4.5rem) 1.25rem clamp(3rem, 7vw, 5.5rem);
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-brand {
    width: fit-content;
    max-width: 100%;
    margin-bottom: 1.1rem;
  }
  .hero-logo {
    width: 100%;
    height: auto;
    display: block;
    color: var(--of-accent);
    margin-bottom: 0.4rem;
  }
  .hero-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    letter-spacing: 0.5px;
    margin: 0;
  }
  .hero-title .accent {
    color: var(--of-text-bright);
  }
  .hero-sub {
    color: var(--of-text-2);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 34rem;
    margin: 0 0 1.75rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .trust {
    color: var(--of-text-bright);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .hero-shot {
    position: relative;
    aspect-ratio: 16 / 10;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35), 0 0 0 1px var(--of-border-subtle);
    overflow: hidden;
  }
  .shot-bar {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    background: var(--of-bg-elevated);
    border-bottom: 1px solid var(--of-border-subtle);
    position: relative;
    z-index: 1;
  }
  .shot-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--of-border-strong);
  }

  .carousel {
    position: absolute;
    inset: 36px 0 0 0;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }
  .carousel-track {
    display: flex;
    height: 100%;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .carousel-slide {
    flex-shrink: 0;
    width: 100%;
    height: 100%;
  }
  .carousel-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .carousel-dots {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
    z-index: 2;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    border: none;
    cursor: pointer;
    padding: 0;
    background: rgba(255, 255, 255, 0.35);
    transition: width 0.25s ease, background 0.25s ease;
  }
  .dot.active {
    width: 20px;
    background: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-shot {
      max-height: 320px;
    }
  }
  @media (max-width: 480px) {
    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
    }
    .hero-shot {
      max-height: 220px;
    }
  }
</style>

<script>
  const track = document.getElementById('hero-track') as HTMLElement | null;
  const dotsContainer = document.getElementById('hero-dots');
  const carousel = document.getElementById('hero-carousel');
  const dots = Array.from(dotsContainer?.querySelectorAll<HTMLButtonElement>('.dot') ?? []);
  let current = 0;
  let timer: ReturnType<typeof setInterval> | undefined;

  function goTo(index: number) {
    dots[current]?.classList.remove('active');
    dots[current]?.setAttribute('aria-selected', 'false');
    current = index;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    dots[current]?.classList.add('active');
    dots[current]?.setAttribute('aria-selected', 'true');
  }

  function next() { goTo((current + 1) % dots.length); }
  function start() { timer = setInterval(next, 4000); }
  function stop()  { clearInterval(timer); }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', (e) => { e.preventDefault(); stop(); goTo(i); start(); });
  });

  carousel?.addEventListener('mouseenter', stop);
  carousel?.addEventListener('mouseleave', start);

  start();
</script>
