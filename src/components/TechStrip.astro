---
const stack = ['SvelteKit', 'SQLite', 'Docker', 'Leaflet'];
---

<section class="tech">
  <div class="tech-inner">
    <p class="tech-line">
      Open source and self-hosted — <strong>your data never leaves your server.</strong>
    </p>
    <ul class="tech-badges">
      {stack.map((t) => <li class="chip">{t}</li>)}
    </ul>
  </div>
</section>

<style>
  .tech {
    border-bottom: 1px solid var(--of-border-subtle);
  }
  .tech-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .tech-line {
    color: var(--of-text-2);
    margin: 0;
    font-size: 0.95rem;
  }
  .tech-line strong {
    color: var(--of-text-bright);
    font-weight: 600;
  }
  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tech-badges .chip {
    font-size: 0.8rem;
    padding: 5px 14px;
    font-family: var(--font-mono);
  }
</style>
