---
import ThemeToggle from './ThemeToggle.astro';
import { SITE } from '../consts';
import { languages, languageCodes, defaultLang, type Lang } from '../i18n/ui';
import { useTranslations, localeUrl } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<div class="floating-actions">
  <div class="lang-switcher">
    <button
      id="lang-btn"
      class="fab"
      type="button"
      aria-label={t.lang.switch}
      title={t.lang.switch}
      aria-haspopup="true"
      aria-expanded="false"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z"></path>
      </svg>
    </button>

    <ul id="lang-menu" class="lang-menu" role="menu" aria-label={t.lang.switch} hidden>
      {
        languageCodes.map((code) => (
          <li role="none">
            <a
              role="menuitem"
              class:list={['lang-item', { active: code === lang }]}
              href={localeUrl(code, '')}
              data-lang={code}
              hreflang={code}
              lang={code}
              aria-current={code === lang ? 'true' : undefined}
            >
              {languages[code]}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <a class="fab" href={SITE.github} target="_blank" rel="noopener" aria-label="View on GitHub">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.71 5.41-5.28 5.69.42.36.79 1.07.79 2.16 0 1.56-.02 2.82-.02 3.2 0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z" />
    </svg>
  </a>

  <ThemeToggle />
</div>

<style>
  .floating-actions {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .fab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-control);
    border: 1px solid var(--of-border);
    background: color-mix(in srgb, var(--of-bg-elevated) 85%, transparent);
    color: var(--of-text-2);
    cursor: pointer;
    text-decoration: none;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .fab:hover {
    color: var(--of-accent);
    border-color: var(--of-accent-border);
  }
  .floating-actions :global(.theme-toggle) {
    width: 44px;
    height: 44px;
    background: color-mix(in srgb, var(--of-bg-elevated) 85%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* Language switcher popover */
  .lang-switcher {
    position: relative;
    width: 44px;
    height: 44px;
  }
  .lang-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    margin: 0;
    padding: 0.35rem;
    list-style: none;
    min-width: 11rem;
    background: color-mix(in srgb, var(--of-bg-elevated) 92%, transparent);
    border: 1px solid var(--of-border);
    border-radius: var(--radius-control);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .lang-menu[hidden] {
    display: none;
  }
  .lang-item {
    display: block;
    padding: 0.45rem 0.7rem;
    border-radius: calc(var(--radius-control) - 4px);
    color: var(--of-text-2);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.2;
    white-space: nowrap;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .lang-item:hover {
    color: var(--of-text-bright);
    background: var(--of-bg-hover);
  }
  .lang-item.active {
    color: var(--of-accent);
    font-weight: 600;
  }
</style>

<script>
  const btn = document.getElementById('lang-btn');
  const menu = document.getElementById('lang-menu');

  function openMenu() {
    if (!menu || !btn) return;
    menu.hidden = false;
    btn.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    if (!menu || !btn) return;
    menu.hidden = true;
    btn.setAttribute('aria-expanded', 'false');
  }
  function toggleMenu() {
    if (menu?.hidden) openMenu();
    else closeMenu();
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Persist the explicit language choice so the auto-detect on `/` respects it.
  menu?.querySelectorAll<HTMLAnchorElement>('.lang-item').forEach((item) => {
    item.addEventListener('click', () => {
      try {
        localStorage.setItem('of-lang', item.dataset.lang || '');
      } catch (e) {}
    });
  });

  // Close on outside click or Escape.
  document.addEventListener('click', (e) => {
    if (!menu || menu.hidden) return;
    const target = e.target as Node;
    if (!menu.contains(target) && target !== btn) closeMenu();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
