---
import FeatureCard from './FeatureCard.astro';
import { useTranslations, localeUrl } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// Icons: small inline stroke SVGs (currentColor).
const s = (paths: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

// Icon + doc link per feature. Order MUST match `features.items` in src/i18n/ui.ts;
// the title/desc/badge text is pulled from the active language's dictionary.
const meta = [
  { href: '/docs/features/lures', icon: s('<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>') },
  { href: '/docs/features/spots', icon: s('<path d="M12 21s-7-6.3-7-11a7 7 0 0 1 14 0c0 4.7-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/>') },
  { href: '/docs/features/catches', icon: s('<ellipse cx="14" cy="12" rx="7" ry="5"/><path d="M7 12L2 7M7 12L2 17"/><circle cx="18" cy="10" r="1.3" fill="currentColor" stroke="none"/><path d="M11 7Q14 4 17 7"/>') },
  { href: '/docs/features/tackle', icon: s('<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18"/>') },
  { href: '/docs/features/stats', icon: s('<path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/>') },
  { href: '/docs/ai/ai-features', icon: s('<rect x="4" y="7" width="16" height="12" rx="3"/><path d="M12 7V4M9 13h.01M15 13h.01M2 12h2M20 12h2"/>') },
  { href: '/docs/multi-user/authentication', icon: s('<circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M16 5a3 3 0 0 1 0 6M21 20a6 6 0 0 0-4-5.6"/>') },
  { href: '/docs/features/share-links', icon: s('<circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.2 10.8 15.8 7.2M8.2 13.2l7.6 3.6"/>') },
  { href: '/docs/api/rest-api', icon: s('<path d="M8 6 3 12l5 6M16 6l5 6-5 6M13 4l-2 16"/>') },
  { href: '/docs/backup/backup-restore', icon: s('<path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 3v5h-5"/>') },
  { href: '/docs/features/languages', icon: s('<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3Z"/>') },
  { href: '/docs/features/themes', icon: s('<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/>') },
];

const features = t.features.items.map((item, i) => ({
  ...item,
  icon: meta[i].icon,
  href: localeUrl(lang, meta[i].href),
}));
---

<section id="features" class="features">
  <div class="features-inner">
    <header class="section-head">
      <h2>{t.features.heading}</h2>
    </header>

    <div class="feature-grid">
      {
        features.map((f) => (
          <FeatureCard title={f.title} icon={f.icon} badge={f.badge} href={f.href}>
            {f.desc}
          </FeatureCard>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    border-bottom: 1px solid var(--of-border-subtle);
  }
  .features-inner {
    padding: clamp(3.5rem, 7vw, 5.5rem) clamp(1.25rem, 8vw, 6rem);
  }
  .section-head {
    text-align: center;
    margin: 0 0 2.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    white-space: nowrap;
    width: fit-content;
    margin: 0 auto 0.75rem;
  }
  @media (max-width: 640px) {
    .section-head h2 {
      white-space: normal;
      width: auto;
    }
  }
  .section-head p {
    color: var(--of-text-2);
    font-size: 1rem;
    margin: 0;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: stretch;
  }
  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1400px) {
    .feature-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
