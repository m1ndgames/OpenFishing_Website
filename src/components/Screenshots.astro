---
import { SITE } from '../consts';
import { useTranslations, fill } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// Screenshot sources — order MUST match `shots.items` in src/i18n/ui.ts.
const shotSrcs = [
  '/screenshots/lure-grid.jpg',
  '/screenshots/catch-detail.jpg',
  '/screenshots/spot-map.jpg',
  '/screenshots/stats.jpg',
  '/screenshots/chatbot.jpg',
];
const shots = t.shots.items.map((item, i) => ({ ...item, src: shotSrcs[i] }));
---

<section class="shots">
  <div class="shots-inner">
    <div class="shot-grid" id="shot-grid">
      {
        shots.map((shot) => (
          <button
            class="card card-hover shot-tile"
            data-src={shot.src}
            data-alt={shot.alt}
            aria-label={fill(t.shots.viewAria, { label: shot.label })}
          >
            <img
              src={shot.src}
              alt={shot.alt}
              loading="lazy"
              onerror="this.closest('.shot-tile')?.classList.add('missing')"
            />
            <span class="shot-caption">{shot.label}</span>
            <span class="shot-ph" aria-hidden="true">{shot.label}</span>
          </button>
        ))
      }

      <!-- Demo CTA tile -->
      <a class="card shot-tile shot-demo" href={SITE.demo} target="_blank" rel="noopener" aria-label={t.shots.openDemoAria}>
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="demo-label">{t.shots.demoLabel}</span>
        <span class="demo-sub">{t.shots.demoSub}</span>
      </a>
    </div>
  </div>

  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label={t.shots.dialogLabel} hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label={t.shots.close}>&times;</button>
    <img id="lightbox-img" src="" alt="" />
  </div>
</section>

<style>
  .shots {
    border-bottom: 1px solid var(--of-border-subtle);
    background: radial-gradient(60% 500px at 50% 0%, var(--of-accent-glow), transparent 100%);
  }
  .shots-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 5.5rem) 1.25rem;
  }
  .section-head {
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 2.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    margin: 0 0 0.75rem;
  }
  .section-head p {
    color: var(--of-text-2);
    margin: 0;
  }

  .shot-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 480px) {
    .shot-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .shot-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .shot-tile {
    position: relative;
    padding: 0;
    cursor: zoom-in;
    aspect-ratio: 16 / 10;
    background: linear-gradient(160deg, var(--of-bg-surface), var(--of-bg-elevated));
  }
  .shot-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .shot-caption {
    position: absolute;
    left: 10px;
    bottom: 10px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--of-text-bright);
    background: color-mix(in srgb, var(--of-bg-base) 70%, transparent);
    backdrop-filter: blur(4px);
    border: 1px solid var(--of-border);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
  }
  .shot-ph {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    color: var(--of-text-3);
    font-size: 1.05rem;
  }
  .shot-tile.missing { cursor: default; }
  .shot-tile.missing img,
  .shot-tile.missing .shot-caption { display: none; }
  .shot-tile.missing .shot-ph { display: flex; }

  .shot-demo {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--of-accent);
    background: linear-gradient(135deg, var(--of-accent-bg), var(--of-accent-bg-hover));
    border: 1px solid var(--of-accent-border) !important;
    cursor: pointer;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .shot-demo:hover {
    box-shadow: 0 0 0 1px var(--of-accent-border), 0 8px 32px var(--of-accent-glow);
  }
  .demo-label {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--of-text-bright);
  }
  .demo-sub {
    font-size: 0.8rem;
    color: var(--of-text-2);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: color-mix(in srgb, var(--of-bg-base) 88%, transparent);
    backdrop-filter: blur(6px);
  }
  .lightbox[hidden] { display: none; }
  .lightbox img {
    max-width: min(1100px, 92vw);
    max-height: 86vh;
    border-radius: 12px;
    border: 1px solid var(--of-border-strong);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
  }
  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    width: 42px;
    height: 42px;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--of-text-bright);
    background: var(--of-bg-elevated);
    border: 1px solid var(--of-border);
    border-radius: var(--radius-control);
    cursor: pointer;
  }
</style>

<script>
  const grid = document.getElementById('shot-grid');
  const lb = document.getElementById('lightbox') as HTMLElement | null;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const close = document.getElementById('lightbox-close');

  function openLightbox(src: string, alt: string) {
    if (!lb || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    if (!lb) return;
    lb.hidden = true;
    document.body.style.overflow = '';
  }

  grid?.querySelectorAll('.shot-tile').forEach((tile) => {
    tile.addEventListener('click', () => {
      if (tile.classList.contains('missing')) return;
      openLightbox(tile.getAttribute('data-src') || '', tile.getAttribute('data-alt') || '');
    });
  });
  close?.addEventListener('click', closeLightbox);
  lb?.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
