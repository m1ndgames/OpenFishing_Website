---
interface Props {
  title: string;
  icon: string;
  badge?: string;
  href?: string;
}
const { title, icon, badge, href } = Astro.props;
const Tag = href ? 'a' : 'article';
---

<Tag class="card card-hover feature" href={href || undefined}>
  <div class="feature-header">
    <div class="feature-icon" set:html={icon} aria-hidden="true"></div>
    <h3 class="feature-title">
      {title}
      {badge && <span class="chip feature-badge">{badge}</span>}
    </h3>
  </div>
  <p class="feature-desc"><slot /></p>
</Tag>

<style>
  .feature {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .feature-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .feature-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 11px;
    background: var(--of-accent-bg-hover);
    border: 1px solid var(--of-accent-border);
    color: var(--of-accent);
  }
  .feature-icon :global(svg) {
    width: 22px;
    height: 22px;
  }
  .feature-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--of-text-bright);
    margin: 0;
  }
  .feature-badge {
    font-weight: 500;
    color: var(--of-text-3);
    text-transform: lowercase;
  }
  .feature-desc {
    flex: 1;
    color: var(--of-text-2);
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
  }
</style>
