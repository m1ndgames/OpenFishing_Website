---
// Shared marketing landing page, rendered once per locale.
// English is served at `/` (src/pages/index.astro); the other locales are
// generated by src/pages/[lang]/index.astro.
import Landing from '../layouts/Landing.astro';
import FloatingActions from './FloatingActions.astro';
import FishBackground from './FishBackground.astro';
import Hero from './Hero.astro';
import Features from './Features.astro';
import DemoCallout from './DemoCallout.astro';
import Quickstart from './Quickstart.astro';
import Screenshots from './Screenshots.astro';
import Footer from './Footer.astro';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = defaultLang } = Astro.props;
---

<Landing lang={lang}>
  <main id="main">
    <Hero lang={lang} />
    <Features lang={lang} />
    <DemoCallout lang={lang} />
    <Quickstart lang={lang} />
    <Screenshots lang={lang} />
  </main>
  <Footer lang={lang} />
  <FloatingActions lang={lang} />
  <FishBackground />
</Landing>
