---
import { SITE } from '../consts';
---

<section class="demo">
  <div class="demo-inner">
    <div class="demo-card">
      <div class="demo-copy">
        <h2>Take it for a cast.</h2>
        <p>
          Explore a fully populated OpenFishing instance
        </p>
      </div>
      <a class="btn-primary demo-btn" href={SITE.demo} target="_blank" rel="noopener">
        Open the live demo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .demo {
    background: linear-gradient(135deg, var(--of-accent-bg), var(--of-accent-bg-hover));
    border-top: 1px solid var(--of-accent-border);
    border-bottom: 1px solid var(--of-accent-border);
    box-shadow: 0 8px 40px var(--of-accent-glow);
  }
  .demo-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) 1.25rem;
  }
  .demo-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .demo-copy {
    max-width: 40rem;
  }
  .demo-copy h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin: 0 0 0.5rem;
  }
  .demo-copy p {
    color: var(--of-text-2);
    margin: 0;
    line-height: 1.6;
  }
  .demo-btn {
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
