---
// Fishing line from top-right corner. Lure tilts with line.
// Fish chases lure. At bottom: swallows lure and hangs on line.
// Back at top while caught: brief struggle, then pulled out of frame.
---

<svg id="fish-line-svg" class="fish-line-svg" aria-hidden="true">
  <line id="fish-line-el" x1="100%" y1="0" x2="0" y2="0"
        stroke-width="1" stroke-linecap="round" />
</svg>

<!-- Lure -->
<div id="fish-lure" class="fish-lure" aria-hidden="true">
  <div id="lure-rotate" class="lure-rotate">
    <div class="lure-bob">
      <svg viewBox="0 0 14 46" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="7" cy="2" r="2" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.6"/>
        <ellipse cx="7" cy="16" rx="6" ry="11" fill="currentColor" opacity="0.75"/>
        <ellipse cx="7" cy="18" rx="3" ry="6" fill="white" opacity="0.15"/>
        <line x1="7" y1="27" x2="7" y2="38" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.55"/>
        <path d="M7 38 Q7 44 13 44" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" opacity="0.55"/>
      </svg>
    </div>
  </div>
</div>

<!-- Fish
     fish-outer:  position:fixed, left/top via JS
     fish-angle:  base hang-rotation via JS, pivot at mouth (right center)
     fish-inner:  swim / hang-swing / struggle animation + opacity
-->
<div id="fish-outer" class="fish-outer" aria-hidden="true">
  <div id="fish-angle" class="fish-angle">
    <div class="fish-inner">
      <svg viewBox="0 0 64 40" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 20L0 4V36L8 20Z"/>
        <ellipse cx="36" cy="20" rx="28" ry="15"/>
        <path d="M25 9Q35 2 45 9Z"/>
        <circle cx="54" cy="16" r="3" fill="white" opacity="1"/>
        <circle cx="55" cy="16" r="1.3" fill="currentColor" opacity="1"/>
      </svg>
    </div>
  </div>
</div>

<style>
  /* ── Line ─────────────────────────────────────────────── */
  .fish-line-svg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: visible;
  }
  #fish-line-el {
    stroke: color-mix(in srgb, var(--of-border-strong) 45%, transparent);
  }

  /* ── Lure ─────────────────────────────────────────────── */
  .fish-lure {
    position: fixed;
    z-index: 0;
    pointer-events: none;
    color: var(--of-accent);
  }
  .lure-rotate {
    width: 14px;
    margin-left: -7px;
    transform-origin: top center;
  }
  .lure-bob {
    animation: lure-bob 2.4s ease-in-out infinite;
    transform-origin: top center;
  }
  @keyframes lure-bob {
    0%,  100% { transform: translateY(0px); }
    50%        { transform: translateY(6px); }
  }

  /* ── Fish ─────────────────────────────────────────────── */
  .fish-outer {
    position: fixed;
    width: 52px;
    z-index: 0;
    pointer-events: none;
    will-change: left, top, transform, opacity;
    transition: left 0.12s linear, top 0.5s ease;
  }
  /* pivot = mouth (right center): rotation here keeps mouth at hook point */
  .fish-angle {
    width: 100%;
    transform-origin: 100% 50%;
  }
  .fish-inner {
    color: var(--of-accent);
    opacity: 1;
    animation: fish-swim 2.8s ease-in-out infinite;
  }
  .fish-inner svg { display: block; width: 100%; height: auto; }

  @keyframes fish-swim {
    0%,  100% { transform: translateY(0)    rotate(0deg);  }
    25%        { transform: translateY(-5px) rotate(-3deg); }
    75%        { transform: translateY(5px)  rotate(3deg);  }
  }

  /* ── Resisting while being pulled back (scroll up) ──── */
  .fish-outer.resisting .fish-inner {
    animation: fish-resist 0.7s ease-in-out infinite;
  }
  @keyframes fish-resist {
    0%,  100% { transform: translateY(0)    rotate(-6deg); }
    50%        { transform: translateY(-5px) rotate(-10deg); }
  }

  /* ── Bite snap ───────────────────────────────────────── */
  .fish-outer.biting .fish-inner {
    animation: fish-bite-snap 0.12s cubic-bezier(0.2, 0, 0.4, 1) forwards;
  }
  @keyframes fish-bite-snap {
    0%   { transform: scale(1)   translateX(0);    }
    45%  { transform: scale(1.5) translateX(12px); }
    100% { transform: scale(1)   translateX(0);    }
  }

  /* ── Caught: hangs along line, same opacity as lure ─── */
  .fish-outer.caught .fish-inner {
    opacity: 1;
    animation: fish-hang-swing 3s ease-in-out infinite;
  }
  @keyframes fish-hang-swing {
    0%,  100% { transform: rotate(0deg);  }
    30%        { transform: rotate(4deg);  }
    70%        { transform: rotate(-3deg); }
  }

  /* ── Struggling before pull-out ─────────────────────── */
  .fish-outer.struggling .fish-inner {
    animation: fish-struggle 0.1s ease-in-out infinite;
  }
  @keyframes fish-struggle {
    0%,  100% { transform: rotate(-7deg) translateY(-3px); }
    50%        { transform: rotate(7deg)  translateY(3px);  }
  }

  @media (max-width: 1200px) {
    .fish-outer, .fish-lure, .fish-line-svg { display: none; }
  }
</style>

<script>
  const lineEl       = document.getElementById('fish-line-el')  as SVGLineElement | null;
  const lureEl       = document.getElementById('fish-lure')     as HTMLElement    | null;
  const lureRotateEl = document.getElementById('lure-rotate')   as HTMLElement    | null;
  const fishEl       = document.getElementById('fish-outer')    as HTMLElement    | null;
  const fishAngleEl  = document.getElementById('fish-angle')    as HTMLElement    | null;

  const MIN_X     = 8;
  const MAX_X     = 87;
  const LURE_Y    = 38;   // vh
  const FISH_DIST = 12;   // vw — trailing distance before swallow

  let lureX       = MIN_X;
  let lureDir     = 1;
  let lastScrollY = window.scrollY;
  let swallowed   = false;
  let pulledOut   = false;

  function fishWidth() {
    return window.innerWidth <= 640 ? 38 : 52;
  }

  /* angle (from vertical) of line from hookX to top-right corner */
  function angleDeg(xVw: number): number {
    const px = xVw / 100 * window.innerWidth;
    const py = LURE_Y / 100 * window.innerHeight;
    return Math.atan2(window.innerWidth - px, py) * 180 / Math.PI;
  }

  function setLineEnd(xVw: number) {
    if (!lineEl) return;
    const px = xVw / 100 * window.innerWidth;
    const py = LURE_Y / 100 * window.innerHeight;
    lineEl.setAttribute('x2', String(Math.round(px)));
    lineEl.setAttribute('y2', String(Math.round(py)));
  }

  /* scroll-down: fish trails LEFT of lure, faces right
     scroll-up:   fish sits RIGHT of lure, faces left (right side of line) */
  function setFishChasing() {
    if (!fishEl || !fishAngleEl) return;
    const fishX = lureDir >= 0
      ? Math.max(1,  Math.min(91, lureX - FISH_DIST))   // behind lure
      : Math.max(1,  Math.min(91, lureX + FISH_DIST));   // right of retreating lure
    fishEl.style.left           = `${fishX}vw`;
    fishEl.style.top            = `${LURE_Y}vh`;
    fishEl.style.transform      = lureDir >= 0 ? 'scaleX(1)' : 'scaleX(-1)';
    fishAngleEl.style.transform = '';
    fishEl.classList.toggle('resisting', lureDir < 0);
  }

  /* caught position — fish-outer always at calc(lureX - fw), mouth = right edge = lureX.
     Flip is applied to fish-angle with transform-origin: 100% 50% (= mouth pivot),
     so mouth stays at lureX regardless of direction — no transition mismatch. */
  function setCaughtPosition() {
    if (!fishEl || !fishAngleEl) return;
    const fw = fishWidth();

    fishEl.style.left      = `calc(${lureX}vw - ${fw}px)`;
    fishEl.style.top       = `${LURE_Y}vh`;
    fishEl.style.transform = 'none';

    if (lureDir >= 0) {
      // hang along line
      fishAngleEl.style.transform = `rotate(${angleDeg(lureX) - 90}deg)`;
    } else {
      // flip around mouth (right-center pivot) — mouth stays at lureX
      fishAngleEl.style.transform = 'scaleX(-1)';
    }

    setLineEnd(lureX);
  }

  function applyPositions() {
    if (pulledOut) return;
    if (!swallowed) {
      if (lureEl) {
        lureEl.style.left = `${lureX}vw`;
        lureEl.style.top  = `${LURE_Y}vh`;
      }
      if (lureRotateEl) {
        lureRotateEl.style.transform = `rotate(${angleDeg(lureX)}deg)`;
      }
      setLineEnd(lureX);
      setFishChasing();
    } else {
      setCaughtPosition();
    }
  }

  /* ── Swallow ─────────────────────────────────────────── */
  function triggerSwallow() {
    if (!fishEl || !fishAngleEl) return;
    const fw = fishWidth();

    // snap: fish darts to lure with a scale punch
    fishEl.classList.remove('resisting');
    fishEl.classList.add('biting');
    fishEl.style.transition     = 'left 0.08s cubic-bezier(0.2, 0, 0.2, 1), top 0.08s ease';
    fishEl.style.left           = `calc(${lureX}vw - ${fw}px)`;
    fishEl.style.top            = `${LURE_Y}vh`;
    fishEl.style.transform      = 'none';
    fishAngleEl.style.transform = '';

    setTimeout(() => {
      fishEl.classList.remove('biting');
      if (lureEl) lureEl.style.visibility = 'hidden';
      fishEl.classList.add('caught');
      fishEl.style.transition = 'left 0.15s linear, top 0.4s ease';
      setCaughtPosition();

      // brief moment on the hook, then pulled out
      setTimeout(triggerPullOut, 120);
    }, 110);
  }

  /* ── Pull out ────────────────────────────────────────── */
  function triggerPullOut() {
    if (!fishEl || pulledOut || !swallowed) return;
    pulledOut = true;

    // face right (toward top-right pull direction), clear hang rotation
    if (fishAngleEl) fishAngleEl.style.transform = '';
    fishEl.style.transform = 'none';

    // phase 1: struggle once
    fishEl.classList.remove('caught');
    fishEl.classList.add('struggling');
    fishEl.style.transition = 'none';

    // line follows fish in real time via rAF
    let lineRaf: number;
    function trackLine() {
      if (!fishEl || !lineEl) return;
      const r = fishEl.getBoundingClientRect();
      if (r.width > 0) {
        lineEl.setAttribute('x2', String(Math.round(r.right)));
        lineEl.setAttribute('y2', String(Math.round(r.top + r.height * 0.5)));
      }
      lineRaf = requestAnimationFrame(trackLine);
    }
    lineRaf = requestAnimationFrame(trackLine);

    setTimeout(() => {
      if (!fishEl) return;
      fishEl.classList.remove('struggling');

      // tilt 45° left as fish is yanked out
      if (fishAngleEl) {
        fishAngleEl.style.transition = 'transform 0.3s ease-out';
        fishAngleEl.style.transform  = 'rotate(-45deg)';
      }

      // phase 2: yank to top-right
      fishEl.style.transition =
        'left 1.1s cubic-bezier(0.4, 0, 1, 0.7), top 1.1s cubic-bezier(0.4, 0, 1, 0.7), opacity 0.9s ease-in';
      fishEl.style.left    = '108vw';
      fishEl.style.top     = '-22vh';
      fishEl.style.opacity = '0';
    }, 400);

    setTimeout(() => {
      cancelAnimationFrame(lineRaf);
      if (fishEl)  fishEl.style.visibility  = 'hidden';
      if (lineEl)  lineEl.style.opacity     = '0';
    }, 1600);
  }

  /* ── Scroll ──────────────────────────────────────────── */
  function onScroll() {
    if (pulledOut) return;

    const scrollY   = window.scrollY;
    const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
    const progress  = scrollY / maxScroll;

    const newLureX = MIN_X + progress * (MAX_X - MIN_X);
    lureDir = newLureX > lureX ? 1 : newLureX < lureX ? -1 : lureDir;
    lureX   = newLureX;
    lastScrollY = scrollY;

    if (progress >= 0.98 && !swallowed) {
      swallowed = true;
      triggerSwallow();
    }

    if (swallowed && !pulledOut && progress <= 0.02) {
      triggerPullOut();
      return;
    }

    applyPositions();
  }

  applyPositions();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
