---
import '../styles/global.css';
import { SITE } from '../consts';
import { useTranslations, localeUrl } from '../i18n/utils';
import { defaultLang, languageCodes, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  image?: string;
}

const { lang = defaultLang, title, description, image = '/og-image.png' } = Astro.props;

const t = useTranslations(lang);
const resolvedTitle = title ?? t.meta.title;
const resolvedDescription = description ?? t.meta.description;

const siteBase = Astro.site ?? SITE.domain;
const canonical = new URL(Astro.url.pathname, siteBase);
const ogImage = new URL(image, siteBase);

// hreflang alternates for the landing page in every locale (+ x-default → English).
const alternates = languageCodes.map((code) => ({
  hreflang: code,
  href: new URL(localeUrl(code, ''), siteBase).href,
}));
const xDefaultHref = new URL(localeUrl(defaultLang, ''), siteBase).href;

// Structured data (JSON-LD): helps search engines understand OpenFishing as a
// free, open-source self-hosted app and surface it in rich results.
const origin = new URL(siteBase).origin;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${origin}/#website`,
      url: `${origin}/`,
      name: 'OpenFishing',
      description: resolvedDescription,
      inLanguage: lang,
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${origin}/#app`,
      name: 'OpenFishing',
      description: resolvedDescription,
      applicationCategory: 'LifestyleApplication',
      operatingSystem: 'Docker, Linux, Web',
      url: `${origin}/`,
      image: ogImage.href,
      inLanguage: lang,
      isAccessibleForFree: true,
      license: 'https://www.gnu.org/licenses/agpl-3.0.html',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@type': 'Organization', name: 'OpenFishing', url: SITE.github },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- hreflang alternates for the localized landing pages -->
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenFishing" />
    <meta property="og:locale" content={lang} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

    <!-- No-flash theme bootstrap: dark is the default; only a stored choice
         switches to light (so the site always opens dark per spec). -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('of-theme') === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>

    <!-- First-visit language auto-detect: on the English root, and only until the
         visitor has made an explicit choice, redirect to the matching locale based
         on their browser language. The floating switcher persists 'of-lang'. -->
    <script is:inline>
      (function () {
        try {
          if (location.pathname !== '/') return;
          if (localStorage.getItem('of-lang')) return;
          var supported = ['de', 'fr', 'es', 'it', 'nl', 'pl', 'pt', 'uk'];
          var sys = (navigator.language || '').slice(0, 2).toLowerCase();
          if (supported.indexOf(sys) !== -1) {
            location.replace('/' + sys + '/');
          }
        } catch (e) {}
      })();
    </script>

    <!-- Fonts (Carter One explicitly included) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Carter+One&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
